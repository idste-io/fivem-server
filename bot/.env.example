# FiveM server
FIVEM_HOST=http://127.0.0.1:30120
FIVEM_SERVER_ID=vq3rbm5
CONNECT_URL=play.invoxio.work

# Shared secret for bot<->FiveM API calls (set same value in eonexis-discord-link shared/config.lua)
