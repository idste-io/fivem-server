# Eonexis Discord Bot — copy to .env and fill in values
# NEVER commit .env to git

BOT_TOKEN=your_bot_token_here
CLIENT_ID=1439269702982439005
GUILD_ID=1370155044074426368

# Role IDs
ADMIN_ROLE_ID=1370155044120563887
VERIFIED_ROLE_ID=replace_with_verified_member_role_id

# Owner Discord user ID (always has admin)
OWNER_USER_ID=1443842518075707552

# Channel IDs
UPDATE_CHANNEL_ID=1521149280495337522
ADMIN_CHANNEL_ID=1521266367767253052
JOIN_LEAVE_CHANNEL_ID=1521265403265941574
VERIFY_CHANNEL_ID=1521265452402344036
